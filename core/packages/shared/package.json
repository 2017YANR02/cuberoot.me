{
  "name": "@cuberoot/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./nemesizer-format": {
      "node": "./dist/nemesizer_format.js",
      "default": "./src/nemesizer_format.ts"
    },
    "./wca-events": {
      "node": "./dist/wca_events.js",
      "default": "./src/wca_events.ts"
    },
    "./scramble-length": {
      "node": "./dist/scramble_length.js",
      "default": "./src/scramble_length.ts"
    },
    "./comp-schedule": {
      "node": "./dist/comp_schedule.js",
      "default": "./src/comp_schedule.ts"
    },
    "./alg": "./src/alg.ts",
    "./alg-notation": {
      "node": "./dist/alg_notation.js",
      "default": "./src/alg_notation.ts"
    },
    "./skewb-pyramid-svg": {
      "node": "./dist/skewb_pyramid_svg.js",
      "default": "./src/skewb_pyramid_svg.ts"
    },
    "./skewb-notation": {
      "node": "./dist/skewb_notation.js",
      "default": "./src/skewb_notation.ts"
    },
    "./admin": {
      "node": "./dist/admin.js",
      "default": "./src/admin.ts"
    },
    "./account": {
      "node": "./dist/account.js",
      "default": "./src/account.ts"
    },
    "./result-penalty": {
      "node": "./dist/result_penalty.js",
      "default": "./src/result_penalty.ts"
    },
    "./cubing-slug": {
      "node": "./dist/cubing_slug.js",
      "default": "./src/cubing_slug.ts"
    },
    "./comp-series": "./src/comp_series.ts",
    "./wca-round": {
      "node": "./dist/wca_round.js",
      "default": "./src/wca_round.ts"
    },
    "./payment": {
      "node": "./dist/payment.js",
      "default": "./src/payment.ts"
    },
    "./data/*.json": "./data/*.json"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "~5.7.0"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}

