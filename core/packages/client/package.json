{
  "name": "@cuberoot/client",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/predev-clean.mjs && next dev -H 127.0.0.1 -p 3000",
    "dev:clean": "node scripts/predev-clean.mjs --wipe-next && next dev -H 127.0.0.1 -p 3000",
    "dev:safe": "node scripts/dev-safe.mjs",
    "build": "pnpm -F @cuberoot/shared build && pnpm -F @cuberoot/visualcube build && node scripts/build-cubing-worker.mjs && next build",
    "start": "next start -H 127.0.0.1 -p 3000",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit",
    "reg:check": "node scripts/reg-check.mjs",
    "reg:clauses": "node scripts/build-reg-clauses.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint ."
  },
  "dependencies": {
