            </tr>
            <tr>
              <td>BTM (block turn)</td>
              <td className="num">36</td>
              <td className="num">≤ 16</td>
              <td>{lang === 'zh' ? '宽幅 + 切片; 进一步缩短' : 'wide + slice; shortens further'}</td>
