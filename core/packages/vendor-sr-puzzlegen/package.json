{
  "name": "@cuberoot/vendor-sr-puzzlegen",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./dist/index.js",
      "default": "./src/index.ts"
    }
  },
  "files": ["dist", "src"],
  "scripts": {
    "build": "tsc -b && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "sr-puzzlegen": "^1.0.4"
  },
  "devDependencies": {
    "esbuild": "^0.27.4",
    "typescript": "~5.7.0"
  }
}
