# Database (PostgreSQL 13)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=recon_user
DB_PASS=your_password_here
DB_NAME=cuberoot_db

# JWT
JWT_SECRET=change-this-to-a-random-string

# WCA OAuth (https://www.worldcubeassociation.org/oauth/applications)
WCA_CLIENT_ID=your_wca_client_id
WCA_CLIENT_SECRET=your_wca_client_secret
WCA_REDIRECT_URI=http://localhost:3000/auth/callback

# Server
PORT=3001

# WCA API egress 代理(/v1/wca-proxy/*)——仅 CI 抓取脚本用。
# WCA 对 GH runner IP 段返 403,故 update_upcoming.yml 经本服务器代理出网。
# 留空 = 路由 fail-closed 返 404(功能关闭)。配则填一段高熵随机串,
# 同一值也要存进 GitHub repo secret `WCA_PROXY_SECRET`(workflow 用它发 X-Proxy-Secret 头)。
WCA_PROXY_SECRET=

# ── 会员订阅支付 ──
# 多 provider:按渠道择优 —— 支付宝渠道优先用官方支付宝,微信渠道优先用官方微信支付,
# 都没配则回落虎皮椒聚合支付;三者皆空 = 支付关闭,退化为「仅 admin 手动开通」。
# 异步回调 / 跳回用的对外地址(notify 必须公网可达):
PUBLIC_API_ORIGIN=https://api.cuberoot.me
PUBLIC_SITE_ORIGIN=https://www.cuberoot.me

# 官方支付宝(电脑/手机网站支付,公钥模式 —— 营业执照 + 已 ICP 备案即可申请)
# 开放平台创建「网页&移动应用」自研应用 → 开通「电脑网站支付」+「手机网站支付」→ 用公钥模式。
# ALIPAY_PRIVATE_KEY 填商户应用私钥(PKCS8),ALIPAY_PUBLIC_KEY 填支付宝公钥。单行 base64 或 PEM 均可。
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
# 沙箱网关:https://openapi-sandbox.dl.alipaydev.com/gateway.do
# ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do

# 官方微信支付(APIv3 —— Native 扫码 + H5;个人独资企业可开,无对公账户可用法人本人银行卡认证)
# WECHAT_APPID 须与商户号绑定;WECHAT_API_V3_KEY 为 32 字节 APIv3 密钥;
# WECHAT_PRIVATE_KEY 填商户 API 私钥(apiclient_key.pem 内容);WECHAT_CERT_SERIAL 为商户证书序列号。
# WECHAT_PLATFORM_PUBKEY 选填(配则额外验回调应答签名;不配仅靠 GCM 解密鉴权,已足够安全)。
WECHAT_APPID=
WECHAT_MCHID=
WECHAT_API_V3_KEY=
WECHAT_CERT_SERIAL=
WECHAT_PRIVATE_KEY=
# WECHAT_PLATFORM_PUBKEY=

# 虎皮椒 xunhupay 聚合支付(兜底:个人无执照也可开;有官方后可不填)
# 在 https://www.xunhupay.com 注册 → 拿 APPID + APPSECRET。渠道是账号级,
# 若分别申请了微信、支付宝两个账号,再填 WECHAT_/ALIPAY_ 覆盖。
XUNHUPAY_APPID=
XUNHUPAY_APPSECRET=
# XUNHUPAY_WECHAT_APPID=
# XUNHUPAY_WECHAT_APPSECRET=
# XUNHUPAY_ALIPAY_APPID=
# XUNHUPAY_ALIPAY_APPSECRET=

# Traffic analytics
# Daily-rotating visitor-id hashes mix this in; rotating it invalidates prior UV mapping.
ANALYTICS_SALT=change-to-random-string
# Optional override for MaxMind GeoLite2 mmdb path (default: /usr/share/GeoIP/GeoLite2-Country.mmdb).
# GEOIP_MMDB=/usr/share/GeoIP/GeoLite2-Country.mmdb

# wca-monitor 推送(从 Python /opt/wca-monitor 移植)
# MONITORS_ENABLED=0 → 5 个监控不启动(代码随版本上线但休眠);=1 才跑。
# MONITOR_PUSH_ENABLED=0 → 跑但只 DRY 日志不真推 Bark(双跑期对照旧 Python);=1 才真推。
# 灰度顺序:部署(都 0)→ MONITORS_ENABLED=1 双跑对照 → MONITOR_PUSH_ENABLED=1 真推 → 停 Python。
MONITORS_ENABLED=0
BARK_DEVICE_KEY=
BARK_SERVER=https://api.day.app
MONITOR_PUSH_ENABLED=0
MONITOR_RECORD_TAGS=WR,CR,NR
MONITOR_NR_COUNTRIES=CN,US,AU,CA,PL,KR,RU

# 关注选手「往期成绩变更」监控(/wca/result-watch)—— 独立于上面 5 个实时监控的门控。
# RESULT_WATCH_ENABLED=1 才慢周期(默认 6h)diff WCA 全生涯成绩,检出成绩取消/修正/纪录标记变动写库。
# Bark 真推仍受 MONITOR_PUSH_ENABLED 控(关时只 DRY 日志,但变更照常入库,页面有数据)。
RESULT_WATCH_ENABLED=0
# MONITOR_PAST_RESULTS_INTERVAL_MS=21600000   # 轮询间隔 ms,默认 6h,最短 30min
