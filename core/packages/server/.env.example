# 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=trainer
DB_PASS=your_password_here
DB_NAME=trainer_db

# JWT
JWT_SECRET=change-this-to-a-random-string

# WCA OAuth (https://www.worldcubeassociation.org/oauth/applications)
WCA_CLIENT_ID=your_wca_client_id
WCA_CLIENT_SECRET=your_wca_client_secret
WCA_REDIRECT_URI=http://localhost:5173/trainer/auth/callback

# Server
PORT=3001
