# Database (PostgreSQL 13)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=recon_user
DB_PASS=your_password_here
DB_NAME=cuberoot_db

# JWT
JWT_SECRET=change-this-to-a-random-string

# WCA OAuth (https://www.worldcubeassociation.org/oauth/applications)
WCA_CLIENT_ID=your_wca_client_id
WCA_CLIENT_SECRET=your_wca_client_secret
WCA_REDIRECT_URI=http://localhost:5173/auth/callback

# Server
PORT=3001

# Traffic analytics
# Daily-rotating visitor-id hashes mix this in; rotating it invalidates prior UV mapping.
ANALYTICS_SALT=change-to-random-string
# Optional override for MaxMind GeoLite2 mmdb path (default: /usr/share/GeoIP/GeoLite2-Country.mmdb).
# GEOIP_MMDB=/usr/share/GeoIP/GeoLite2-Country.mmdb
