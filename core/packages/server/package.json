{
  "name": "@cuberoot/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:local": "pwsh -NoProfile -File scripts/dev-local.ps1",
    "seed:local-alg": "pwsh -NoProfile -File scripts/seed-local-alg.ps1",
    "build:bundle": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=esm --outfile=dist/server.bundle.js --sourcemap --banner:js=\"import { createRequire } from 'module'; const require = createRequire(import.meta.url);\"",
    "start": "node dist/server.bundle.js",
    "typecheck": "tsc --noEmit",
    "gen-title": "tsx src/tools/gen_title.ts",
    "gen-glossary": "tsx scripts/gen-glossary.ts",
    "gen-wiki-backfill": "tsx scripts/gen-wiki-backfill.ts"
  },
  "dependencies": {
    "@cuberoot/shared": "workspace:*",
    "@cuberoot/visualcube": "workspace:*",
    "@hono/node-server": "^1.0.0",
    "@types/ws": "^8.18.1",
    "cubing": "^0.63.3",
    "hono": "^4.0.0",
    "jsonwebtoken": "^9.0.0",
    "linkedom": "^0.18.12",
    "maxmind": "^5.0.6",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "@cuberoot/vendor-sr-puzzlegen": "workspace:*",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.6",
    "esbuild": "^0.27.4",
    "tsx": "^4.0.0",
    "typescript": "~5.7.0"
  }
}
