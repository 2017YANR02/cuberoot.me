# 多 set 配置:每项一个数据来源,UI 上 dropdown 切换
# 每个 set 的 CSV 目录可含以下文件:std.csv / eo.csv / pair.csv / pseudo.csv / pseudo_pair.csv / f2leo.csv / pseudo_f2leo.csv
# 缺失的变体 CSV 会被跳过并打警告(不再是必需,build 不再抛错)
sets:
  - key: wca
    label: WCA
    label_zh: WCA
    csv_dir: D:/cube/scramble/wca_scramble/stats
    scrambles_txt: D:/cube/scramble/wca_scramble/wca_scrambles_no_wide_move.txt
  - key: xcross_2_col_10f
    label: dual-color 10f xcross
    label_zh: 双色底 10f xcross
    csv_dir: D:/cube/scramble/xcross_2_col_10f/stat
    scrambles_txt: D:/cube/scramble/xcross_2_col_10f/scrambles.txt

# 老格式(单 set,等价于 sets: [{key: wca, ...}])仍兼容:
# csv_dir: D:/cube/scramble/wca_scramble/stats
