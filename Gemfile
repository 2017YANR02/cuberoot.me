source 'https://gems.ruby-china.com'

# 核心 Jekyll 引擎
gem "jekyll", "~> 4.3"

# Windows 用户必备：优化文件夹监控性能
# 听从 Bundler 的建议，直接使用 :windows，简洁又标准
gem "wdm", ">= 0.1.1", :platforms => [:windows]

# 确保在 Ruby 3.x 环境下有服务器可用
gem "webrick", "~> 1.8"

# GitHub Pages 常用插件分组
group :jekyll_plugins do
  gem "jekyll-sitemap"
  gem "jekyll-optional-front-matter"
end